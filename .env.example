# --- Plantilla de variables de entorno ---
# Copia este archivo a uno llamado  .env  (sin .example) y pega ahi tu llave real.
# El archivo .env NUNCA se sube a Git (esta en .gitignore).

# Llave de Google Places API (la tienes en Google Cloud).
GOOGLE_PLACES_API_KEY=pega_aqui_tu_llave

# Nombre del archivo de la base de datos (puedes dejarlo asi).
DATABASE_FILE=bragi_crm.db
