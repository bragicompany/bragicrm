# --- Plantilla de variables de entorno ---
# Copia este archivo a uno llamado  .env  (sin .example) y pega ahi tu llave real.
# El archivo .env NUNCA se sube a Git (esta en .gitignore).

# Llave de Google Places API (la tienes en Google Cloud).
GOOGLE_PLACES_API_KEY=pega_aqui_tu_llave

# Nombre del archivo de la base de datos (puedes dejarlo asi).
DATABASE_FILE=bragi_crm.db

# Llave de la API de Anthropic (Claude) para escribir los correos (Fase 4).
# Se obtiene en console.anthropic.com (con saldo). NO es la de Claude Code.
ANTHROPIC_API_KEY=pega_aqui_tu_llave_de_anthropic

# --- Envío de correo con SendGrid (Fase 5) ---
SENDGRID_API_KEY=pega_aqui_tu_llave_de_sendgrid
SENDER_EMAIL=booking@bragicompany.com
SENDER_NAME=Bragi Company
REPLY_TO=booking@bragicompany.com
# Dirección física para el pie de los correos (requisito legal CAN-SPAM).
BRAGI_ADDRESS=Bragi Company, [calle y número], [ciudad, estado, ZIP], USA

# --- Webhook de aperturas (Fase 6C-2) ---
# Token secreto que protege el endpoint /webhook/sendgrid. Inventa una cadena larga
# y la misma va al final de la URL que configuras en SendGrid:
#   https://TU-APP.../webhook/sendgrid?token=ESTE_VALOR
# (Solo aplica cuando la app esté en la nube; en local no recibe eventos reales.)
SENDGRID_WEBHOOK_TOKEN=inventa_un_codigo_secreto_largo
